{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "english-now",
    "compatibility_date": "2025-09-02",
    "compatibility_flags": [
        "nodejs_compat"
    ],
    "main": "@tanstack/react-start/server-entry",
    "vars": {
        "VITE_SERVER_URL": "https://api.english.now",
        "VITE_PADDLE_CLIENT_TOKEN": "live_907997c6cb446428064482c8ca8",
        "VITE_PADDLE_ENVIRONMENT": "production",
        "VITE_PADDLE_PRICE_MONTHLY": "pri_01kkpcnsmrmwdg4vt1kymx106d",
        "VITE_PADDLE_PRICE_YEARLY": "pri_01kmnaepmmwxkx2b3276k35601"
    },
    "observability": {
        "enabled": true,
        "traces": {
            "enabled": true,
            "destinations": [
                "english-now-sentry-traces"
            ],
            // traces sample rate of 5%
            "head_sampling_rate": 0.05,
            // (optional) set to false to only export traces to your
            // destination without persisting them in the Cloudflare dashboard
            "persist": false
        },
        "logs": {
            "enabled": true,
            "destinations": [
                "english-now-sentry-logs"
            ],
            // logs sample rate of 60%
            "head_sampling_rate": 0.6,
            // (optional) set to false to only export logs to your
            // destination without persisting them in the Cloudflare dashboard
            "persist": false
        }
    }
}